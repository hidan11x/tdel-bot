BOT_TOKEN=your_bot_token_here
ADMIN_IDS=8601339909
DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# Data Providers
YFINANCE_ENABLED=true
BINANCE_ENABLED=true
NEWS_NOTIFICATIONS_ENABLED=false
NEWS_INTERVAL_HOURS=12
SAUDI_EXCHANGE_ENABLED=true
SAUDI_PRICES_TTL_SECONDS=300
SAUDI_FREE_FALLBACK_ENABLED=true
# Optional: Saudi stock API. Create a free key at https://www.sahmk.sa/en/developers/docs
# SAHMK_API_KEY=
# SAHMK_BASE_URL=https://app.sahmk.sa/api/v1
# SAHMK_SYNC_LIMIT=450
# Optional: use a SimpleScraper JSON endpoint as Saudi Exchange fallback
# SIMPLESCRAPER_API_KEY=
# SIMPLESCRAPER_SAUDI_API_URL=
# Optional: override the discovered Saudi Exchange internal endpoint
# SAUDI_EXCHANGE_ENDPOINT=

# Optional dashboard settings
# DASHBOARD_BASE_URL=https://your-app.up.railway.app
# DASHBOARD_SECRET=change-this-secret
# DASHBOARD_PORT=8080

# Market Hours
SAUDI_MARKET_OPEN=10:00
SAUDI_MARKET_CLOSE=15:00
US_MARKET_OPEN=15:30
US_MARKET_CLOSE=22:00
MARKET_TIMEZONE=Asia/Riyadh

# Default Limits
FREE_SCANS_DAILY=5
FREE_ALERTS=3
FREE_WATCHLIST=5
BASIC_SCANS_DAILY=30
BASIC_ALERTS=15
BASIC_WATCHLIST=20
PRO_SCANS_DAILY=100
PRO_ALERTS=50
PRO_WATCHLIST=50
VIP_SCANS_DAILY=-1
VIP_ALERTS=-1
VIP_WATCHLIST=-1

# Pricing
BASIC_PRICE=29
PRO_PRICE=79
VIP_PRICE=199
LIFETIME_PRICE=499
